{
  "name": "@redemeine/testing",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "bun test ./test",
    "bench": "bun run ./bench/testing-suite.bench.ts",
    "lint": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@redemeine/mirage": "workspace:*",
    "@redemeine/projection": "workspace:*",
    "@redemeine/saga": "workspace:*",
    "immer": "^10.1.1"
  }
}
