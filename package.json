{
  "name": "redemeine",
  "version": "0.1.0",
  "description": "Sane defaults CQRS/ES aggregates library",
  "author": "Your Name/Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/redemeine.git"
  },
  "main": "dist/cjs/redemeine.js",
  "module": "dist/esm/redemeine.js",
  "types": "dist/types/redemeine.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "redemeine": "./dist/cjs/bin/redemeine.js"
  },
  "exports": {
    ".": {
      "types": "./dist/types/redemeine.d.ts",
      "import": "./dist/esm/redemeine.js",
      "require": "./dist/cjs/redemeine.js",
      "default": "./dist/cjs/redemeine.js"
    },
    "./reflector": {
      "types": "./dist/types/reflector.d.ts",
      "import": "./dist/esm/reflector.js",
      "require": "./dist/cjs/reflector.js",
      "default": "./dist/cjs/reflector.js"
    }
  },
  "scripts": {
    "build": "node ./bin/build-dual.js",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test-compile": "tsc -p ./",
    "docs:typedoc": "typedoc",
    "docs:audit": "tsx bin/redemeine-reflector.ts --verify-tsdoc",
    "docs:llms": "tsx bin/redemeine-reflector.ts --generate-llms-ctx > llms.txt",
    "docs:install": "npm install --prefix website",
    "docs:dev": "npm run start --prefix website",
    "docs:build": "npm run build --prefix website"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "docusaurus-plugin-typedoc": "^1.4.2",
    "eslint": "^8.57.1",
    "eslint-config-surikat": "^5.0.0",
    "jest": "^29.7.0",
    "prettier-config-surikaterna": "^1.0.1",
    "ts-jest": "^29.1.5",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-missing-exports": "^4.1.2",
    "typescript": "^5.9.3",
    "utility-types": "^3.11.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "dependencies": {
    "immer": "^10.1.1",
    "type-fest": "^5.5.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  }
}
